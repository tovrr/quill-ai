{
  "name": "quill-ai",
  "version": "1.0.0",
  "description": "Personal AI agent and builder for research, writing, coding, and app/page generation.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/tovrr/quill-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/tovrr/quill-ai.git"
  },
  "bugs": {
    "url": "https://github.com/tovrr/quill-ai/issues"
  },
  "keywords": [
    "ai-agent",
    "nextjs",
    "react",
    "typescript",
    "builder",
    "llm"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "cross-env NEXT_DISABLE_TURBOPACK=1 next dev",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:chatbot": "node scripts/test-chatbot-responses.mjs",
    "test:agent-remediation": "node scripts/test-agent-remediation.mjs",
    "test:execution": "node scripts/test-execution-service.mjs",
    "test:smoke": "node scripts/smoke-api.mjs",
    "test:auth": "node scripts/test-auth-regressions.mjs",
    "test:rag": "node scripts/test-rag-regressions.mjs",
    "test:autopilot-cron": "node scripts/test-autopilot-cron-regressions.mjs",
    "test:workflows": "node scripts/test-account-workflows.mjs",
    "test:contracts": "node scripts/test-response-contracts.mjs",
    "test": "vitest",
    "test:ci": "npm run test:smoke && npm run test:auth && npm run test:rag && npm run test:autopilot-cron && npm run test:chatbot && npm run test:agent-remediation && npm run test:contracts",
    "audit:chat-render": "node scripts/audit-chat-render.mjs",
    "audit:ui-standards": "node scripts/ui-standards.mjs audit --write-report",
    "enforce:ui-standards": "node scripts/ui-standards.mjs enforce",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "gen:ai-rules": "node scripts/gen-ai-rules.mjs",
    "check:ai-rules": "node scripts/check-ai-rules.mjs",
    "guardrails:check": "node scripts/check-guardrails.mjs",
    "prepare": "husky install"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/react": "^3.0.143",
    "@e2b/code-interpreter": "^2.4.0",
    "@heroicons/react": "^2.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss7-compat": "^2.2.17",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "ai": "^6.0.141",
    "autoprefixer": "^10.5.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "modern-normalize": "^3.0.1",
    "next": "^16.2.3",
    "postcss": "^8.5.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "@tailwindcss/oxide-linux-x64-musl": "4.2.2",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0",
    "@tailwindcss/oxide-win32-x64-msvc": "4.2.2",
    "lightningcss-win32-x64-msvc": "1.32.0"
  },
  "overrides": {
    "defu": "^6.1.5",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.27.5"
    },
    "@esbuild-kit/esm-loader": {
      "esbuild": "0.27.5"
    }
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.3",
    "husky": "^8.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vitest": "^1.2.1"
  }
}
