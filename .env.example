# Quill AI — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Get yours at: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Authentication ───────────────────────────────────────────────────────────
# Better Auth secret — use a high-entropy mixed-character secret.
# Example generator: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Optional: dedicated encryption key for MCP OAuth secrets/tokens at rest.
# If omitted, BETTER_AUTH_SECRET is used as fallback key material.
MCP_OAUTH_ENCRYPTION_KEY=

# Public base URL of your app (used by Better Auth for redirects and cookies)
# Development:  http://localhost:3000
# Production:   https://yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated list of additional trusted origins for auth requests.
# Useful for www + apex domains and preview URLs.
# Example: https://quill-ai.com,https://www.quill-ai.com
BETTER_AUTH_TRUSTED_ORIGINS=

# ── AI ───────────────────────────────────────────────────────────────────────
# Google AI Studio API key (for Gemini chat + Imagen image generation)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: OpenRouter key for fast/free mode routing
# If set, fast mode will auto-select the best available free model from OpenRouter.
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: enable OpenRouter as primary provider for fast mode.
# Default is false for reliability (Gemini fast mode is used first when available).
OPENROUTER_FAST_ENABLED=false

# Optional: pin a specific free model instead of auto-selecting.
# Leave blank to let the app pick the highest-scoring model from OpenRouter.
# Examples: google/gemma-3-27b-it:free, qwen/qwen3-8b:free
OPENROUTER_FREE_MODEL=

# Optional: override default model per tier without redeploying.
# Defaults: fast=gemini-2.5-flash-lite, thinking=gemini-2.5-flash, advanced=gemini-2.5-pro
FAST_MODEL_OVERRIDE=
THINKING_MODEL_OVERRIDE=
ADVANCED_MODEL_OVERRIDE=

# Optional: readiness probe timeout in milliseconds.
HEALTH_CHECK_TIMEOUT_MS=1500

# Optional: cache external provider probe results for readiness checks.
# Lower values increase freshness but also outbound probe volume.
HEALTH_PROVIDER_PROBE_CACHE_MS=30000

# Optional: exact pricing inputs for model usage telemetry.
# Set these to your real contracted/provider prices so /api/admin/model-usage
# reflects actual spend instead of usage-only telemetry.
PRICE_GEMINI_25_FLASH_LITE_INPUT_PER_1M_USD=
PRICE_GEMINI_25_FLASH_LITE_OUTPUT_PER_1M_USD=
PRICE_GEMINI_25_FLASH_INPUT_PER_1M_USD=
PRICE_GEMINI_25_FLASH_OUTPUT_PER_1M_USD=
PRICE_GEMINI_25_PRO_INPUT_PER_1M_USD=
PRICE_GEMINI_25_PRO_OUTPUT_PER_1M_USD=
PRICE_OPENROUTER_INPUT_PER_1M_USD=
PRICE_OPENROUTER_OUTPUT_PER_1M_USD=
PRICE_IMAGEN_4_FAST_PER_IMAGE_USD=

# Optional: Tavily API key for live web search inside chat.
# If set, signed-in users can enable Search in the composer.
# Get key at: https://app.tavily.com/home
TAVILY_API_KEY=

# Optional: max sources to retrieve per searched turn.
WEB_SEARCH_MAX_RESULTS=5

# Optional: per-user daily search quotas.
# Free signed-in users get a lower cap, paid users get a higher cap.
WEB_SEARCH_DAILY_REQUESTS_FREE=20
WEB_SEARCH_DAILY_REQUESTS_PAID=100

# ── Code Execution (Local or Remote) ──────────────────────────────────────────
# 1. LOCAL EXECUTION (development only; requires Docker)
QUILL_SANDBOX_CONTAINER_ENABLED=false

# 2. REMOTE EXECUTION (production; supports E2B, Modal, custom service)
#
# Choose one:
# - EXECUTION_SERVICE_PROVIDER=e2b      (for E2B.dev sandboxes)
# - EXECUTION_SERVICE_PROVIDER=modal    (for Modal serverless)
# - EXECUTION_SERVICE_PROVIDER=custom   (for custom execution API)
#
# Then set the corresponding credentials below.

EXECUTION_SERVICE_PROVIDER=

# E2B configuration (if EXECUTION_SERVICE_PROVIDER=e2b)
# Get your API key at: https://e2b.dev/keys
E2B_API_KEY=

# Modal configuration (if EXECUTION_SERVICE_PROVIDER=modal)
# Get credentials at: https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_WEBHOOK_URL=

# Custom execution service configuration (if EXECUTION_SERVICE_PROVIDER=custom)
# URL should be the base endpoint of your execution service (e.g., https://executor.example.com)
# The service will receive POST requests at /execute with { code, language, timeoutMs }
# and should return { ok, stdout, stderr, exitCode, durationMs, error? }
EXECUTION_SERVICE_URL=
EXECUTION_SERVICE_API_KEY=

# ── Quotas (messages per user per day) ──────────────────────────────────────
# fast     = free mode
# thinking = think mode
# advanced = pro mode
# Production-tuned defaults (adjust from real traffic):
FREE_DAILY_MESSAGES=60
THINK_DAILY_MESSAGES=30
PRO_DAILY_MESSAGES=100

# ── API burst limits (requests per minute) ───────────────────────────────────
# Production-tuned defaults (adjust from real traffic):
API_CHAT_REQUESTS_PER_MINUTE=20
API_IMAGE_REQUESTS_PER_MINUTE=6

# Optional: distributed rate limiting backend (recommended in multi-instance deployments).
# If omitted, the app falls back to in-memory process-local buckets.
# Create at https://upstash.com and paste the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Private operational endpoints ─────────────────────────────────────────────
# Protects /api/metrics (use a long random token in production)
API_METRICS_TOKEN=

# ── Access control (optional) ────────────────────────────────────────────────
# If true, all authenticated users can use Think/Pro (legacy behavior).
ALLOW_ALL_AUTH_MODES=false

# Comma-separated allowlists for paid-mode access (Think/Pro).
# Leave empty if no paid users yet.
PAID_USER_IDS=
PAID_USER_EMAILS=

# Optional: default paid trial length (in days) for authenticated users.
PAID_TRIAL_DAYS=7

# Optional: if true, entitlement resolver fails closed when DB lookup fails.
ENTITLEMENTS_STRICT_MODE=false

# Optional: set true to enable verbose request-shape logging in /api/chat.
DEBUG_CHAT_LOGS=false
